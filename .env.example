# 複製此檔案為 .env，並填入您的 API 金鑰
# 檔案應放置在本目錄中以實現全局共用

# 1. 【Groq API 引擎】（預設優先 / 高隱私 / 免費額度）
# 適合場合：預設的轉錄引擎。適合單人演講、課程錄音、或一般會議轉錄。
# 必須填入您的 Groq API 金鑰：
GROQ_API_KEY=your_groq_api_key_here

# 2. 【AssemblyAI API 引擎】（進階高精度說話者分離方案）
# 適合場合：多人會議、需要精準區分「說話者 A、說話者 B」與時間戳記的場合。
# 必須填入您的 AssemblyAI API 金鑰：
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# ==========================================
# 語音壓縮與偵測參數設定（選填，僅在 Groq API 模式下生效）：
# ==========================================
# 預設壓縮位元率（預設值為 24k，可填 24k、32k、48k，建議維持 24k 以追求最大錄音時長）
AUDIO_COMPRESSION_BITRATE=24k

# 物理撞擊聲/突發巨響本機偵測倍數（預設值為 20，局部絕對振幅超過全局平均值 20 倍即判定為疑似巨響）
DETECT_PEAK_MULTIPLIER=20