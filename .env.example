# 複製此檔案為 .env，並填入您的 API 金鑰
# 檔案應放置在本目錄中以實現全局共用

# 1. 【Gemini API 引擎】（預設）
# 前往 https://aistudio.google.com/apikey 取得 API 金鑰：
GEMINI_API_KEY=your_gemini_api_key_here

# 可選：指定 Gemini 模型（預設為 gemini-2.5-flash）
# 可切換為任何支援音訊多模態輸入的 Gemini 模型，例如：
#   gemini-3.5-flash / gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# 2. 【AssemblyAI API 引擎】（進階高精度說話者分離方案）
# 須填入您的 AssemblyAI API 金鑰；如果沒有填入，就使用 Gemini 模型：
ASSEMBLYAI_API_KEY=your_assemblyai_key_here